{
  "name": "apim-e2e-tests",
  "version": "0.0.1",
  "description": "E2E Pact tests for Electronic Prescription Service API",
  "scripts": {
    "test": "vitest run --project e2e-tests --coverage --reporter=default --reporter=junit --outputFile.junit=./junit.xml --poolOptions.forks.maxForks=1",
    "lint": "eslint  --max-warnings 0 --fix --config ../../eslint.config.mjs .",
    "generate-postman-collection": "ts-node postman-pact.ts --use_strict",
    "clear-cache": "rm -rf node_modules/.vitest",
    "create-sandbox-pacts": "vitest run --project e2e-tests specs/sandbox --reporter=default --reporter=junit --outputFile.junit=./junit.xml --poolOptions.forks.maxForks=1",
    "create-live-pacts": "vitest run --project e2e-tests specs/live --reporter=default --reporter=junit --outputFile.junit=./junit.xml --poolOptions.forks.maxForks=1",
    "fetch-apigee-access-token": "ts-node --project tsconfig.json ./auth/src/oauth.ts --use_strict",
    "verify-pacts": "ts-node --project tsconfig.json ./broker/verify.ts --use_strict"
  },
  "author": "NHS Digital",
  "license": "MIT",
  "engines": {
    "node": "24.13.x",
    "npm": "11.6.x"
  },
  "config": {
    "pact_do_not_track": true
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.3.0",
    "@pact-foundation/pact-core": "^19.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.14.0",
    "axios-cookiejar-support": "^6.0.5",
    "jsdom": "^29.0.1",
    "jsonwebtoken": "^9.0.3",
    "lossless-json": "^4.3.0",
    "moment": "^2.30.1",
    "pino": "^10.3.1",
    "tough-cookie": "^6.0.1",
    "tsconfig-paths": "^4.2.0",
    "xml-js": "^1.6.11"
  }
}
