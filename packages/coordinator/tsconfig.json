{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0",
    "strictNullChecks": false,
    "useUnknownInCatchVariables": false,
    "strictPropertyInitialization": false,
    "noImplicitThis": false,
    "types": [
      "node",
      "vitest/globals"
    ],
    "target": "es6",
    "lib": [
      "es2019",
      "DOM"
    ],
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "sourceMap": true,
    // "strict": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "*": [
        "node_modules/*",
        "tests/*"
      ],
      "@models": [
        "../models"
      ],
      "@services": [
        "./src/services"
      ],
      "@resources": [
        "./src/resources"
      ],
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*"
  ],
  "references": [
    {
      "path": "../models"
    }
  ]
}
